<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Esteban Zamora — Work</title>
<link rel="stylesheet" href="style.css">
<style>
  body { padding-top: 64px; }

  .identity {
    display: grid; grid-template-columns: 1fr auto;
    align-items: end; gap: 40px;
    padding: 72px 64px 52px;
    max-width: 1400px; margin: 0 auto;
    border-bottom: 1px solid var(--border);
    animation: fadeUp 0.7s ease forwards;
    position: relative; z-index: 1;
  }
  .identity-name {
    font-family: var(--font-display);
    font-size: clamp(44px,6vw,88px); font-weight: 300;
    line-height: 0.95; letter-spacing: -0.02em; margin-bottom: 24px;
  }
  .identity-name span { display: block; }
  .identity-name span:last-child {
    -webkit-text-stroke: 1px rgba(255,255,255,0.25); color: transparent;
  }
  .identity-bio { font-size:15px;font-weight:300;color:var(--text-muted);max-width:660px;line-height:1.8; }
  .identity-cards { display:flex;flex-direction:column;gap:2px;min-width:210px; }
  .id-card { padding:16px 20px;background:var(--surface);border:1px solid var(--border); }
  .id-card-label { font-family:var(--font-mono);font-size:10px;letter-spacing:0.12em;color:var(--text-muted);text-transform:uppercase;margin-bottom:4px; }
  .id-card-val { font-family:var(--font-display);font-size:28px;font-weight:300;color:var(--text); }
  .id-card-sub { font-size:11px;font-weight:300;color:var(--text-muted);margin-top:2px; }

  .projects-wrap { padding:64px 64px 120px;max-width:1400px;margin:0 auto;position:relative;z-index:1; }
  .projects-header { margin-bottom:56px; }
  .projects-title { font-family:var(--font-display);font-size:clamp(36px,4vw,60px);font-weight:300;line-height:1.08;letter-spacing:-0.01em; }
  .projects-title em { font-style:italic;color:var(--accent); }
  .projects-sub { margin-top:16px;font-size:14px;font-weight:300;color:var(--text-muted);max-width:500px;line-height:1.7; }

  .projects-grid { display:grid;grid-template-columns:repeat(12,1fr);gap:2px; }
  .project-card {
    position:relative;background:var(--surface);border:1px solid var(--border);
    overflow:hidden;cursor:pointer;transition:border-color 0.3s,transform 0.3s;
    animation:fadeUp 0.6s ease forwards;opacity:0;
  }
  .project-card:hover { border-color:var(--border-hover);transform:translateY(-2px);z-index:2; }
  .project-card:nth-child(1){grid-column:span 7;animation-delay:0.05s;}
  .project-card:nth-child(2){grid-column:span 5;animation-delay:0.1s;}
  .project-card:nth-child(3){grid-column:span 4;animation-delay:0.15s;}
  .project-card:nth-child(4){grid-column:span 4;animation-delay:0.2s;}
  .project-card:nth-child(5){grid-column:span 4;animation-delay:0.25s;}
  .project-card:nth-child(6){grid-column:span 6;animation-delay:0.3s;}
  .project-card:nth-child(7){grid-column:span 6;animation-delay:0.35s;}

  .card-visual { height:200px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center; }
  .project-card:nth-child(1) .card-visual,.project-card:nth-child(2) .card-visual { height:260px; }
  .card-visual-bg { position:absolute;inset:0;transition:transform 0.5s ease; }
  .project-card:hover .card-visual-bg { transform:scale(1.04); }
  .card-v1{background:linear-gradient(135deg,#0a1628,#0d2040 40%,#0a2a1a);}
  .card-v2{background:linear-gradient(135deg,#1a0a0a,#2d1010 40%,#1a1228);}
  .card-v3{background:linear-gradient(135deg,#0a0e1a,#0e1530 50%,#08101a);}
  .card-v4{background:linear-gradient(135deg,#0f0a1a,#1a0f2e 50%,#0a0f1a);}
  .card-v5{background:linear-gradient(135deg,#0a1a14,#0d2818 50%,#0a140e);}
  .card-v6{background:linear-gradient(135deg,#1a120a,#2e1c0a 50%,#1a0f0a);}
  .card-v7{background:linear-gradient(135deg,#0e0a1a,#1a1030 50%,#0a0e1a);}
  .card-circuit { position:absolute;inset:0;z-index:1;opacity:0.07;background-image:linear-gradient(rgba(255,255,255,.5)1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.5)1px,transparent 1px);background-size:32px 32px;transition:opacity 0.3s; }
  .project-card:hover .card-circuit { opacity:0.12; }
  .card-icon { position:relative;z-index:2;font-size:52px;opacity:0.55;filter:drop-shadow(0 0 24px currentColor);transition:opacity 0.3s,filter 0.3s; }
  .project-card:hover .card-icon { opacity:0.85;filter:drop-shadow(0 0 32px currentColor); }
  .card-status { position:absolute;top:16px;right:16px;z-index:3;font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;padding:4px 10px;border-radius:2px;text-transform:uppercase; }
  .status-active { background:rgba(125,211,176,0.12);color:var(--accent2);border:1px solid rgba(125,211,176,0.25); }
  .status-complete { background:rgba(107,114,128,0.12);color:var(--text-muted);border:1px solid rgba(107,114,128,0.2); }
  .card-body { padding:24px 28px 28px; }
  .card-tags { display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px; }
  .card-title { font-family:var(--font-display);font-size:22px;font-weight:400;line-height:1.2;margin-bottom:10px;transition:color 0.2s; }
  .project-card:hover .card-title { color:var(--accent); }
  .card-desc { font-size:13px;font-weight:300;color:var(--text-muted);line-height:1.65; }
  .card-arrow { display:inline-flex;align-items:center;gap:8px;margin-top:20px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.1em;color:var(--accent);opacity:0;transform:translateX(-8px);transition:opacity 0.2s,transform 0.2s; }
  .project-card:hover .card-arrow { opacity:1;transform:translateX(0); }

  @media(max-width:900px){
    .identity{grid-template-columns:1fr;padding:48px 24px 40px;}
    .identity-cards{flex-direction:row;flex-wrap:wrap;}
    .projects-wrap{padding:48px 24px 80px;}
    .projects-grid{grid-template-columns:1fr 1fr;}
    .project-card:nth-child(n){grid-column:span 1;}
    .project-card:nth-child(1){grid-column:span 2;}
  }
</style>
</head>
<body>
